# Application Configuration
# Copy this file to config.yaml and customize for your environment
#
# Environment Variable Substitution:
# - ${VAR_NAME} - Required variable (throws error if not set)
# - ${VAR_NAME:default} - Optional variable with default value

portal:
  url: ${PORTAL_URL:http://provider-portal.api.local}       # Required, Portal API URL, can be overridden by PORTAL_URL env var
  token: ${PORTAL_TOKEN:}                                   # Required, Portal API Token, can be set via PORTAL_TOKEN env var

db:
  url: ""                                                    # Required, no default
  # schema: portal                                           # Optional, PostgreSQL schema name (default: public).
                                                             # Sets search_path on every connection; removes the need
                                                             # to embed options=-c%20search_path=... in the URL.
  # pool:                                                    # db connection pooling
    # max: 20
    # min: 0
    # idleTimeout: 30000
    # connectionTimeout: 2000
    # allowExitOnIdle: false
  # ssl: false
  # ssl: true                                                # Enable SSL without certificate verification
  # ssl:                                                     # SSL with certificate verification
  #   rejectUnauthorized: true
  #   ca: ${DB_SSL_CA}
  #   cert: ${DB_SSL_CERT}
  #   key: ${DB_SSL_KEY}

auth:
  secret: ""                                                 # Required, at least 32 characters. Generate with: openssl rand -base64 32
  # adminUserIds:
  #   - "user_id_1"
  #   - "user_id_2"
  # session:
  #   expiresIn: 604800                                      # 7 days
  #   updateAge: 86400                                       # 1 day
  # emailAndPassword:
  #   enabled: true
  #   requireEmailVerification: false
  # twoFactor:
  #   enabled: false                                          # Enable two-factor auth (TOTP only)
  # socialProviders:                                          # ref: https://www.better-auth.com/docs/reference/options#socialproviders
  #   github:
  #     clientId: ${GITHUB_CLIENT_ID:}                        # GitHub OAuth App Client ID
  #     clientSecret: ${GITHUB_CLIENT_SECRET:}                # GitHub OAuth App Client Secret
  # sso:                                                       # Two-phase sign-in: redirect matching email domains to SSO
  #   providers:
  #     - domains: ["@company\\.com$", "@corp\\.org$"]         # Regular expressions matched against the full email address
  #       providerId: keycloak                                 # Must match a configured genericOAuth providerId

# app:
  # name: "Developer Portal"
  # baseURL: "http://localhost:3001"                          # Public base URL for links, SEO, and auth callbacks
  # trustedOrigins:                                           # Include every browser origin that can access this app
  #  - "http://localhost:3001"
  # apiHub:
  #   enabled: true                                           # Enable the API Hub (show nav item, routes, and sitemap entries). Default: true
  # applicationDetail:
  #  subscriptions: false                                      # Show Subscriptions tab (default: true)
  #  usage: false                                              # Show Usage tab (default: true)
  #  credentialsTabs:
  #    keyAuth: false                                           # Show Key Authentication tab (default: true)
  #    basicAuth: false                                         # Show Basic Authentication tab (default: true)
  #    oauth: false                                             # Show OAuth tab (default: true)
  # signUpConsentLabel: >-
  #   I agree to the <a href="https://example.com/terms" target="_blank" rel="noopener noreferrer">Terms of Service</a> and <a href="https://example.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
  # IMPORTANT: signUpConsentLabel is injected as raw HTML. Only use trusted static content.
