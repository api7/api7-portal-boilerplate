{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["es2021", "dom"],
    "allowJs": true,
    "outDir": "../../dist/out-tsc",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "sourceMap": false,
    "target": "ESNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
  },
  "include": [
    "**/*.ts",
    "playwright.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts",
    "req/**/*.ts",
    "../site/src/types/*.ts",
    "../site/src/constants/*.ts",
  ]
}
