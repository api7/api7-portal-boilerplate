{
  "name": "api7ee-developer-portal",
  "version": "0.7.1",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "cd apps/site && pnpm dev",
    "build": "cd apps/site && pnpm build",
    "preview": "cd apps/site && pnpm preview",
    "lint": "cd apps/site && pnpm lint",
    "lint:fix": "cd apps/site && pnpm lint --fix && pnpm tsc",
    "e2e": "pnpm -F site-e2e --workspace-root e2e",
    "e2e:ui": "cd apps/site-e2e && pnpm e2e:ui",
    "e2e:headed": "cd apps/site-e2e && pnpm e2e:headed"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2"
  },
  "packageManager": "pnpm@9.6.0",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "antd": "6"
      }
    },
    "overrides": {
      "micromatch@<4.0.8": ">=4.0.8",
      "cross-spawn@<6.0.6": ">=6.0.6",
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "nanoid@<3.3.8": ">=3.3.8",
      "nanoid@>=4.0.0 <5.0.9": ">=5.0.9",
      "form-data@<4.0.4": ">=4.0.4",
      "esbuild@<=0.24.2": ">=0.25.0",
      "@babel/*@<7.26.10": ">=7.26.10",
      "undici@>=7.0.0 <7.5.0": ">=7.5.0",
      "brace-expansion@<2.0.3": ">=2.0.3",
      "minimatch@>=8.0.0 <8.0.6": ">=8.0.6",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "lodash@<4.18.0": ">=4.18.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "js-yaml@<4.1.1": ">=4.1.1",
      "tmp@<0.2.4": ">=0.2.4",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0",
      "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
      "undici@<6.24.0": ">=6.24.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "kysely@<=0.28.13": ">=0.28.14",
      "picomatch@<2.3.2": ">=2.3.2",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "defu@<=6.1.4": ">=6.1.5",
      "dompurify@<3.4.0": ">=3.4.0",
      "follow-redirects@<1.16.0": ">=1.16.0",
      "postcss@<8.5.10": ">=8.5.10",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "unhead@<2.1.13": ">=2.1.13 <3.0.0",
      "read-yaml-file": "2.1.0"
    }
  }
}
