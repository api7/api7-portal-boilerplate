{
  "name": "api7ee-developer-portal",
  "version": "0.7.1",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "cd apps/site && pnpm dev",
    "build": "cd apps/site && pnpm build",
    "preview": "cd apps/site && pnpm preview",
    "lint": "cd apps/site && pnpm lint",
    "lint:fix": "cd apps/site && pnpm lint --fix && pnpm tsc",
    "e2e": "pnpm -F site-e2e --workspace-root e2e",
    "e2e:ui": "cd apps/site-e2e && pnpm e2e:ui",
    "e2e:headed": "cd apps/site-e2e && pnpm e2e:headed"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.30.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
